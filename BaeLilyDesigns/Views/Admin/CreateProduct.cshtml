@model BaeLilyDesigns.Models.Product
@{
    ViewData["Title"] = "Add Product";
    ViewData["HidePreorder"] = true;
}

<div style="max-width:700px;margin:40px auto;padding:0 20px;">
    <a asp-action="Products" style="color:#888;text-decoration:none;font-size:0.9rem;">← Back to Products</a>
    <h1 style="font-family:'Cinzel',serif;font-size:1.8rem;color:#2A2118;margin:16px 0 28px;">Add New Product</h1>

    <div style="background:white;border-radius:12px;box-shadow:0 2px 20px rgba(0,0,0,0.06);padding:32px;">
        <form asp-action="CreateProduct" method="post">
            @Html.AntiForgeryToken()
            @await Html.PartialAsync("_ProductForm", Model)
            <div style="display:flex;gap:12px;margin-top:28px;">
                <button type="submit" style="flex:1;padding:14px;background:#2A2118;color:#D4B896;border:none;border-radius:8px;font-family:'Cinzel',serif;font-size:1rem;cursor:pointer;">Create Product</button>
                <a asp-action="Products" style="padding:14px 20px;border:2px solid #ddd;border-radius:8px;color:#666;text-decoration:none;text-align:center;">Cancel</a>
            </div>
        </form>
    </div>
</div>
