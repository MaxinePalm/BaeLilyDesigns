@model List<BaeLilyDesigns.Models.Order>
@{
    ViewData["Title"] = "My Orders";
    ViewData["HidePreorder"] = true;
}

<div style="max-width:800px;margin:60px auto;padding:0 20px;">
    <h1 style="font-family:'Cinzel',serif;font-size:2rem;color:#2A2118;margin-bottom:8px;">My Orders</h1>
    <p style="color:#888;margin-bottom:32px;">Track your pre-orders and order history</p>

    @if (!Model.Any())
    {
        <div style="text-align:center;padding:80px 20px;background:white;border-radius:16px;box-shadow:0 2px 20px rgba(0,0,0,0.06);">
            <div style="font-size:4rem;margin-bottom:16px;">🛍️</div>
            <h2 style="color:#2A2118;font-family:'Cinzel',serif;">No orders yet</h2>
            <p style="color:#888;margin-bottom:24px;">Start shopping and your orders will appear here.</p>
            <a asp-controller="Shop" asp-action="Index" style="display:inline-block;padding:14px 32px;background:#2A2118;color:#D4B896;border-radius:8px;text-decoration:none;font-family:'Cinzel',serif;">Shop Now</a>
        </div>
    }
    else
    {
        <div style="display:flex;flex-direction:column;gap:20px;">
            @foreach (var order in Model)
            {
                <div style="background:white;border-radius:14px;box-shadow:0 2px 20px rgba(0,0,0,0.06);overflow:hidden;">
                    <div style="background:#f5f0e8;padding:18px 24px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;">
                        <div>
                            <span style="font-family:'Cinzel',serif;font-size:1rem;color:#2A2118;">Order #@order.Id</span>
                            <span style="color:#888;font-size:0.85rem;margin-left:12px;">@order.OrderDate.ToString("dd MMM yyyy")</span>
                        </div>
                        <div style="display:flex;align-items:center;gap:12px;">
                            <span style="font-weight:700;color:#2A2118;font-size:1.1rem;">R@order.TotalAmount.ToString("N0")</span>
                            <span style="padding:5px 14px;border-radius:20px;font-size:0.82rem;
                                  background:@(order.Status == "Delivered" ? "#d4edda" : order.Status == "Shipped" ? "#cce5ff" : order.Status == "Cancelled" ? "#fee" : "#fff3cd");
                                  color:@(order.Status == "Delivered" ? "#155724" : order.Status == "Shipped" ? "#004085" : order.Status == "Cancelled" ? "#c00" : "#856404");">
                                @order.Status
                            </span>
                        </div>
                    </div>
                    <div style="padding:20px 24px;">
                        @foreach (var item in order.Items)
                        {
                            <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid #f5f0e8;">
                                <div style="display:flex;align-items:center;gap:12px;">
                                    <span style="font-size:2rem;">@(item.Product?.Emoji ?? "🛍️")</span>
                                    <div>
                                        <div style="font-weight:600;color:#2A2118;">@item.ProductName</div>
                                        <div style="color:#888;font-size:0.85rem;">Size: @item.Size · Qty: @item.Quantity</div>
                                    </div>
                                </div>
                                <span style="font-weight:600;color:#2A2118;">R@((item.Price * item.Quantity).ToString("N0"))</span>
                            </div>
                        }

                        <div style="margin-top:14px;">
                            @{
                                var statusSteps = new[] { "Pending", "Processing", "Shipped", "Delivered" };
                                var currentIdx = Array.IndexOf(statusSteps, order.Status);
                            }
                            @if (order.Status != "Cancelled")
                            {
                                <div style="display:flex;gap:0;">
                                    @for (int i = 0; i < statusSteps.Length; i++)
                                    {
                                        <div style="flex:1;text-align:center;">
                                            <div style="width:28px;height:28px;border-radius:50%;margin:0 auto 6px;line-height:28px;font-size:0.8rem;
                                                  background:@(i <= currentIdx ? "#2A2118" : "#e0d8ce");
                                                  color:@(i <= currentIdx ? "#D4B896" : "#999");">
                                                @(i < currentIdx ? "✓" : (i + 1).ToString())
                                            </div>
                                            <div style="font-size:0.75rem;color:@(i <= currentIdx ? "#2A2118" : "#bbb");">@statusSteps[i]</div>
                                        </div>
                                        @if (i < statusSteps.Length - 1)
                                        {
                                            <div style="flex:none;width:20px;height:2px;background:@(i < currentIdx ? "#2A2118" : "#e0d8ce");margin-top:13px;"></div>
                                        }
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
