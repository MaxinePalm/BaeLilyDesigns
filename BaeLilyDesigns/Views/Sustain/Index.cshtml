@{
    ViewData["Title"] = "Ethics & Sustainability";
    ViewData["HidePreorder"] = true;
}

<div class="sustain-hero">
    <p class="section-label">Our commitments</p>
    <h1 class="section-title">Ethics aren't a <em>feature</em> - they're the foundation</h1>
    <p style="opacity:0.75;font-size:1.05rem;line-height:1.9;margin-top:1.5rem;">Every single purchase supports a chain of choices we're proud of. Here's what that looks like in practice.</p>
</div>

<div class="impact-grid">
    <div class="impact-card reveal">
        <div class="impact-num">70%</div>
        <p class="impact-label">Organic cotton in every garment</p>
    </div>
    <div class="impact-card reveal reveal-delay-1">
        <div class="impact-num">30%</div>
        <p class="impact-label">Recycled polyester from plastic waste</p>
    </div>
    <div class="impact-card reveal reveal-delay-2">
        <div class="impact-num">Fair</div>
        <p class="impact-label">Wages paid above living wage standard</p>
    </div>
</div>

<div style="max-width:1200px;margin:0 auto;padding:3rem 2rem;">
    <div class="values-grid">
        <div class="value-card reveal">
            <div class="value-icon">♻️</div>
            <div class="value-title">Recycled packaging</div>
            <p class="value-text">All packaging is 100% recycled and biodegradable. No single-use plastics, ever. Your hoodie arrives looking beautiful without costing the earth.</p>
        </div>
        <div class="value-card reveal reveal-delay-1">
            <div class="value-icon">🏭</div>
            <div class="value-title">Audited factories</div>
            <p class="value-text">We only work with factories that pass independent ethical audits. Safe conditions, fair pay, no overtime coercion. We visit. We verify.</p>
        </div>
        <div class="value-card reveal reveal-delay-2">
            <div class="value-icon">🌱</div>
            <div class="value-title">Carbon offset shipping</div>
            <p class="value-text">Every shipment is carbon offset through verified reforestation projects. We're actively working toward net-zero logistics by 2026.</p>
        </div>
        <div class="value-card reveal">
            <div class="value-icon">👗</div>
            <div class="value-title">Slow fashion</div>
            <p class="value-text">We don't do flash sales for the sake of it. We make what we sell, and sell what we make. Pre-orders mean no waste, no surplus.</p>
        </div>
        <div class="value-card reveal reveal-delay-1">
            <div class="value-icon">💛</div>
            <div class="value-title">Size inclusivity</div>
            <p class="value-text">Every Bae Lily Designs design comes in XS–3XL at the same price point. Fashion should fit every body, full stop.</p>
        </div>
        <div class="value-card reveal reveal-delay-2">
            <div class="value-icon">🔍</div>
            <div class="value-title">Full transparency</div>
            <p class="value-text">We publish our full supply chain, cost breakdowns, and audit reports. You have every right to know where your money goes.</p>
        </div>
    </div>
</div>
